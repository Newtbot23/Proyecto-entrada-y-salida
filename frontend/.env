# ============================================================================
# Variables de Entorno - React + Vite
# ============================================================================
#
# IMPORTANTE: En Vite, las variables DEBEN empezar con VITE_ para ser
# expuestas al navegador. Las variables sin este prefijo son privadas.
#
# Después de modificar este archivo, REINICIA el servidor de desarrollo (npm run dev)
#
# ============================================================================

# URL de la API de Laravel
# DESARROLLO: Servidor local de Laravel
VITE_API_URL=http://localhost:8000/api

# PRODUCCIÓN: Cambia a tu dominio real
# VITE_API_URL=https://api.tudominio.com/api

# ============================================================================
# INSTRUCCIONES DE USO
# ============================================================================
#
# 1. Copia este archivo a la raíz de tu proyecto React como '.env'
#    Ubicación: frontend/.env
#
# 2. Verifica que .env esté en tu .gitignore para no subir secretos
#
# 3. Accede a las variables en tu código así:
#    const apiUrl = import.meta.env.VITE_API_URL;
#
# 4. Para variables de diferentes entornos:
#    .env                 -> Todas las variables base
#    .env.local           -> Sobreescribe .env (no commitear)
#    .env.development     -> Solo en desarrollo
#    .env.production      -> Solo en producción
#
# ============================================================================

# Otras variables opcionales
VITE_APP_NAME=control de entradas y salida
VITE_APP_VERSION=1.0.0

# Si necesitas habilitar modo debug
# VITE_DEBUG=true
/**
 * Declaración de Tipos para Variables de Entorno - Vite
 * 
 * Este archivo define los tipos TypeScript para las variables de entorno
 * que Vite expone a través de import.meta.env
 * 
 * UBICACIÓN: frontend/src/vite-env.d.ts
 * 
 * Este archivo permite que TypeScript reconozca:
 * - import.meta.env.VITE_API_URL
 * - Otras variables VITE_ que agregues
 * 
 * @version 1.0.0
 */

/// <reference types="vite/client" />

/**
 * Interfaz que define todas las variables de entorno disponibles
 * 
 * IMPORTANTE: Solo las variables que empiezan con VITE_ son accesibles
 * desde el código del navegador.
 * 
 * Para agregar más variables:
 * 1. Agregarlas en .env con prefijo VITE_
 * 2. Declararlas aquí en esta interfaz
 * 3. Reiniciar el servidor de desarrollo
 */
interface ImportMetaEnv {
  /**
   * URL base de la API de Laravel
   * Configurada en .env como VITE_API_URL
   * 
   * Ejemplo: http://localhost:8000/api
   */
  readonly VITE_API_URL: string;
  
  /**
   * Nombre de la aplicación (opcional)
   * Configurada en .env como VITE_APP_NAME
   */
  readonly VITE_APP_NAME?: string;
  
  /**
   * Versión de la aplicación (opcional)
   * Configurada en .env como VITE_APP_VERSION
   */
  readonly VITE_APP_VERSION?: string;
  
  /**
   * Modo de debug (opcional)
   * Configurada en .env como VITE_DEBUG
   */
  readonly VITE_DEBUG?: string;
  
  /**
   * Variables built-in de Vite
   * No necesitas configurarlas, Vite las proporciona automáticamente
   */
  
  /**
   * Modo de ejecución: 'development' | 'production'
   */
  readonly MODE: string;
  
  /**
   * Base URL de la aplicación
   */
  readonly BASE_URL: string;
  
  /**
   * true si está en producción
   */
  readonly PROD: boolean;
  
  /**
   * true si está en desarrollo
   */
  readonly DEV: boolean;
  
  /**
   * true si está en modo SSR (Server-Side Rendering)
   */
  readonly SSR: boolean;
}

/**
 * Extender la interfaz ImportMeta global
 * Esto permite que TypeScript reconozca import.meta.env
 */
interface ImportMeta {
  readonly env: ImportMetaEnv;
}

/**
 * EJEMPLOS DE USO:
 * 
 * // Obtener URL de la API
 * const apiUrl = import.meta.env.VITE_API_URL;
 * console.log(apiUrl); // "http://localhost:8000/api"
 * 
 * // Verificar si está en desarrollo
 * if (import.meta.env.DEV) {
 *   console.log('Modo desarrollo');
 * }
 * 
 * // Verificar si está en producción
 * if (import.meta.env.PROD) {
 *   console.log('Modo producción');
 * }
 * 
 * // Usar variables opcionales con valores por defecto
 * const appName = import.meta.env.VITE_APP_NAME || 'Mi App';
 */