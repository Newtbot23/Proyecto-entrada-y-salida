# ============================================================================
# Variables de Entorno - React + Vite
# ============================================================================
#
# IMPORTANTE: En Vite, las variables DEBEN empezar con VITE_ para ser
# expuestas al navegador. Las variables sin este prefijo son privadas.
#
# Después de modificar este archivo, REINICIA el servidor de desarrollo (npm run dev)
#
# ============================================================================

# URL de la API de Laravel
# DESARROLLO: Servidor local de Laravel
VITE_API_URL=http://localhost:8000/api

# PRODUCCIÓN: Cambia a tu dominio real
# VITE_API_URL=https://api.tudominio.com/api

# ============================================================================
# INSTRUCCIONES DE USO
# ============================================================================
#
# 1. Copia este archivo a la raíz de tu proyecto React como '.env'
#    Ubicación: frontend/.env
#
# 2. Verifica que .env esté en tu .gitignore para no subir secretos
#
# 3. Accede a las variables en tu código así:
#    const apiUrl = import.meta.env.VITE_API_URL;
#
# 4. Para variables de diferentes entornos:
#    .env                 -> Todas las variables base
#    .env.local           -> Sobreescribe .env (no commitear)
#    .env.development     -> Solo en desarrollo
#    .env.production      -> Solo en producción
#
# ============================================================================

# Otras variables opcionales
VITE_APP_NAME=control de entradas y salida
VITE_APP_VERSION=1.0.0

# Si necesitas habilitar modo debug
# VITE_DEBUG=true

/// <reference types="vite/client" />

